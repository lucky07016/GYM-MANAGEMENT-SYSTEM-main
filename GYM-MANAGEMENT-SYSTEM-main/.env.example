# Environment Variables (Copy to .env and fill in values)

# Server Configuration
PORT=3000
NODE_ENV=development

# Optional: Geolocation API Key (for IP-to-location service)
# GEOLOCATION_API_KEY=your_api_key_here

# Optional: Database type (json, mongodb, postgresql)
DB_TYPE=json

# Optional: Session secret
SESSION_SECRET=your_secret_key_here

# Optional: OpenAI for AI Coach (optional — built-in coach works without this)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Email OTP (Gmail app password recommended)
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
